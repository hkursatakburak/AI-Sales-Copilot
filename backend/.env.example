# Bu dosyayı `.env` olarak kopyalayın ve değerleri doldurun.
# `.env` GIT'E EKLENMEZ (bkz. .gitignore). Gerçek anahtarlar burada tutulmaz.

# Genel
COPILOT_ENVIRONMENT=development
COPILOT_LOG_LEVEL=INFO

# CORS (üretimde daraltın). JSON dizi biçimi:
# COPILOT_CORS_ALLOW_ORIGINS=["chrome-extension://<EKLENTI_ID>"]

# LLM — Sprint 3'ten itibaren gerekli olacak (varsayılan sağlayıcı: Claude)
# COPILOT_ANTHROPIC_API_KEY=sk-ant-...
