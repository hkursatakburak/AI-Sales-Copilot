# Bu dosyayı `.env` olarak kopyalayın ve değerleri doldurun.
# `.env` GIT'E EKLENMEZ (bkz. .gitignore). Gerçek anahtarlar burada tutulmaz.

# Genel
COPILOT_ENVIRONMENT=development
COPILOT_LOG_LEVEL=INFO

# CORS (üretimde daraltın). JSON dizi biçimi:
# COPILOT_CORS_ALLOW_ORIGINS=["chrome-extension://<EKLENTI_ID>"]

# LLM sağlayıcı seçimi. Anahtar yoksa scraping-only moda düşülür.
# LLM_PROVIDER=gemini            # veya: claude
#
# Gemini (ücretsiz — https://aistudio.google.com/apikey):
# GEMINI_API_KEY=...
# COPILOT_GEMINI_MODEL=gemini-2.5-flash
#
# Claude:
# ANTHROPIC_API_KEY=sk-ant-...
# COPILOT_LLM_MODEL=claude-opus-4-8   # maliyet için: claude-sonnet-4-6

# Satıcı profili (Sprint 4) — soğuk e-posta/pitch'in "ne sattığımızı" bilmesi için
# COPILOT_SELLER_NAME=Şirketiniz
# COPILOT_SELLER_OFFERING=Ne sattığınızın kısa açıklaması
# COPILOT_SELLER_REP_NAME=Adınız
